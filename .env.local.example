# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# App
# En dev local : http://localhost:3333
# En prod : https://izisolo.fr
NEXT_PUBLIC_APP_URL=https://izisolo.fr

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Resend
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=IziSolo <no-reply@izisolo.fr>

# Stripe (côté pro : ses propres clés pour encaisser ses élèves via Payment Link)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Stripe SaaS (abonnement IziSolo lui-même — comptes Mélutek) ────────
# Webhook signing secret pour /api/stripe/webhook-saas
STRIPE_WEBHOOK_SECRET_SAAS=whsec_...

# Price IDs Stripe (à créer dans dashboard.stripe.com → Products) :
# MENSUEL UNIQUEMENT pour le moment. L'annuel sera ajouté plus tard avec -20%.
#   Solo     12€/mois  → STRIPE_PRICE_ID_SOLO_MENSUEL
#   Pro      24€/mois  → STRIPE_PRICE_ID_PRO_MENSUEL
#   Premium  49€/mois  → STRIPE_PRICE_ID_PREMIUM_MENSUEL
# Trial 14 jours appliqué automatiquement par /api/stripe/checkout-saas.
STRIPE_PRICE_ID_SOLO_MENSUEL=price_...
STRIPE_PRICE_ID_PRO_MENSUEL=price_...
STRIPE_PRICE_ID_PREMIUM_MENSUEL=price_...

# OctoPush (SMS Mélutek global, facturé 0,08€/SMS au pro)
# Doc : https://dev.octopush.com/
OCTOPUSH_LOGIN=...
OCTOPUSH_API_KEY=...
OCTOPUSH_SENDER=IziSolo

# Sentry (optionnel — si vide, monitoring no-op)
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Cron
CRON_SECRET=your-cron-secret-here
